// Dwaar WASM Plugin Interface — example guest copy
//
// This file is a verbatim copy of `crates/dwaar-plugins/wit/dwaar-plugin.wit`.
// Keep them in sync when the host interface changes.

package dwaar:plugin@0.1.0;

interface host {
    get-request-header: func(name: string) -> option<string>;
    list-request-header-names: func() -> list<string>;
    get-response-header: func(name: string) -> option<string>;
    list-response-header-names: func() -> list<string>;
}

world dwaar-plugin {
    import host;

    enum plugin-action {
        continue,
        respond,
        skip,
    }

    record request-info {
        method: string,
        path: string,
        is-tls: bool,
        client-ip: string,
    }

    record response-info {
        status: u16,
    }

    export on-request: func(req: request-info) -> plugin-action;
    export on-response: func(resp: response-info) -> plugin-action;
    export on-body: func(eos: bool) -> plugin-action;
}
